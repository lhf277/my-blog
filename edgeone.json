{
    "headers": [
      {
        "source": "/*",
        "headers": [
          {
            "key": "X-Frame-Options",
            "value": "DENY"
          },
          {
            "key": "Cache-Control",
            "value": "max-age=86400"
          }
        ]
      },
      {
        "source": "/atom.xml",
        "headers":[
          {
            "key": "Access-Control-Allow-Origin",
            "value": "*"
          }
        ]
      }
    ],
    "caches": [
      {
        "source": "/atom.xml",
        "cacheTtl": 0
      },
      {
        "source": "/*",
        "cacheTtl": 86400
      }
    ]

}
